<div class="dataPagePanel">
  <% if (!Array.isArray(runs) || runs.length === 0) { %>
    <div class="muted">No runs found.</div>
  <% } else { %>
    <div class="tableScroll">
      <table class="dataTable monitoringRunsTable">
        <thead>
          <tr>
            <th>Job Type</th>
            <th>Status</th>
            <th>Started</th>
            <th>Finished</th>
            <th>Summary</th>
            <th>Events</th>
          </tr>
        </thead>
        <tbody>
          <% for (const r of runs) { %>
            <% 
              const st = String(r?.status ?? "").toLowerCase();
              let badge = "jobStatusBadge";
              if (st === "running") badge += " jobStatusBadge--running";
              else if (st === "completed") badge += " jobStatusBadge--completed";
              else if (st === "failed") badge += " jobStatusBadge--failed";
            %>
            <tr>
              <td><%= r?.jobType ?? "" %></td>
              <td><span class="<%= badge %>"><%= r?.status ?? "" %></span></td>
              <td><%= formatDateTime(r?.startedAt) %></td>
              <td><%= formatDateTime(r?.finishedAt) %></td>
              <td class="monitoringSummaryCell"><%= r?.summary ?? "" %></td>
              <td>
                <button
                  class="tabBtn"
                  type="button"
                  data-monitoring-action="events"
                  data-run-id="<%= r?.id ?? "" %>"
                >
                  View events
                </button>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  <% } %>
  <%- include("../_pagination", { pagination }) %>
</div>
