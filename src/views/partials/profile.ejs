<% const p = profile || {}; %>
<div class="profilePage dataPagePanel">
  <section class="profileHero" aria-labelledby="profileName">
    <div class="profileHeroMain">
      <div class="profileHeroAvatarShell">
        <% if (p.avatarUrl) { %>
          <img
            id="profileAvatar"
            class="profileHeroAvatar"
            src="<%= p.avatarUrl %>"
            alt=""
            width="112"
            height="112"
            decoding="async"
          />
        <% } else { %>
          <img id="profileAvatar" class="profileHeroAvatar hidden" src="" alt="" width="112" height="112" />
        <% } %>
      </div>
      <div class="profileHeroText">
        <h2 id="profileName" class="profileHeroName"><%= p.name ?? "" %></h2>
        <% if (p.login) { %>
          <div id="profileLogin" class="profileHeroLogin mono">@<%= p.login %></div>
        <% } else { %>
          <div id="profileLogin" class="profileHeroLogin mono hidden" aria-hidden="true"></div>
        <% } %>
        <p id="profileHeadline" class="profileHeroHeadline"><%= p.headline || "—" %></p>
        <% if (p.hireable != null) { %>
          <span
            id="profileHireable"
            class="profileHireableBadge <%= p.hireable ? "profileHireableBadge--yes" : "profileHireableBadge--no" %>"
          >
            <%= p.hireable ? "Open to opportunities" : "Not actively seeking" %>
          </span>
        <% } else { %>
          <span id="profileHireable" class="profileHireableBadge profileHireableBadge--muted hidden"></span>
        <% } %>
      </div>
    </div>

    <dl class="profileContactGrid">
      <div class="profileContactItem">
        <dt>Email</dt>
        <dd id="profileEmail"><%= p.email ? p.email : "—" %></dd>
      </div>
      <div class="profileContactItem">
        <dt>Phone</dt>
        <dd id="profilePhone"><%= p.phoneNumber ? p.phoneNumber : "—" %></dd>
      </div>
    </dl>
    
    <dl class="profileContactGrid">
      <div class="profileContactItem">
        <dt>Job title</dt>
        <dd id="profileEmail"><%= p.jobTitle ? p.jobTitle : "—" %></dd>
      </div>
      <div class="profileContactItem">
        <dt>LinkedIn about</dt>
        <dd id="profilePhone"><%= p.linkedinSummary || "—" %></dd>
      </div>
    </dl>

  </section>
</div>

