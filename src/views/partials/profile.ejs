<% const p = profile || {}; %>
<div class="profilePage dataPagePanel">
  <section class="profileHero" aria-labelledby="profileName">
    <div class="profileHeroMain">
      <div class="profileHeroAvatarShell">
        <% if (p.avatarUrl) { %>
          <img
            id="profileAvatar"
            class="profileHeroAvatar"
            src="<%= p.avatarUrl %>"
            alt=""
            width="112"
            height="112"
            decoding="async"
          />
        <% } else { %>
          <img id="profileAvatar" class="profileHeroAvatar hidden" src="" alt="" width="112" height="112" />
        <% } %>
      </div>
      <div class="profileHeroText">
        <h2 id="profileName" class="profileHeroName"><%= p.name ?? "" %></h2>
        <% if (p.login) { %>
          <div id="profileLogin" class="profileHeroLogin mono">@<%= p.login %></div>
        <% } else { %>
          <div id="profileLogin" class="profileHeroLogin mono hidden" aria-hidden="true"></div>
        <% } %>
        <p id="profileHeadline" class="profileHeroHeadline"><%= p.headline || "—" %></p>
        <% if (p.hireable != null) { %>
          <span
            id="profileHireable"
            class="profileHireableBadge <%= p.hireable ? "profileHireableBadge--yes" : "profileHireableBadge--no" %>"
          >
            <%= p.hireable ? "Open to opportunities" : "Not actively seeking" %>
          </span>
        <% } else { %>
          <span id="profileHireable" class="profileHireableBadge profileHireableBadge--muted hidden"></span>
        <% } %>
      </div>
    </div>

    <dl class="profileContactGrid">
      <div class="profileContactItem">
        <dt>Email</dt>
        <dd id="profileEmail"><%= p.email ? p.email : "—" %></dd>
      </div>
      <div class="profileContactItem">
        <dt>Phone</dt>
        <dd id="profilePhone"><%= p.phoneNumber ? p.phoneNumber : "—" %></dd>
      </div>
    </dl>
    
    <dl class="profileContactGrid">
      <div class="profileContactItem">
        <dt>Job title</dt>
        <dd id="profileEmail"><%= p.jobTitle ? p.jobTitle : "—" %></dd>
      </div>
      <div class="profileContactItem">
        <dt>LinkedIn about</dt>
        <dd id="profilePhone"><%= p.linkedinSummary || "—" %></dd>
      </div>
    </dl>

  </section>
</div>

<div class="card profileUploadCard hidden" id="uploadCard">
  <h2>Upload LinkedIn export</h2>
  <div id="linkedinCredentialsSection" class="hidden">
    <p class="muted">
      Enter your LinkedIn API credentials before uploading the export ZIP. Values are stored on your developer
      record; the access token is encrypted at rest.
    </p>
    <div class="row auth-field">
      <label for="linkedinCredAccessToken">ACCESS_TOKEN</label>
      <input id="linkedinCredAccessToken" type="password" autocomplete="off" placeholder="LinkedIn OAuth access token" />
    </div>
    <div class="row auth-field">
      <label for="linkedinCredPersonId">PERSON_ID</label>
      <input id="linkedinCredPersonId" type="text" autocomplete="off" placeholder="LinkedIn person / member id" />
    </div>
    <div class="row">
      <button type="button" id="btnSaveLinkedinCredentials">Save LinkedIn credentials</button>
    </div>
    <div id="linkedinCredentialsMsg" class="muted auth-msg" aria-live="polite"></div>
  </div>
  <div class="row">
    <span class="muted">GitHub sync is complete. Upload your LinkedIn ZIP export to continue.</span>
  </div>
  <div class="row">
    <label for="linkedinZip">LinkedIn ZIP file</label>
    <input id="linkedinZip" type="file" accept=".zip" />
  </div>
  <div class="row">
    <button id="uploadLinkedinZipBtn">Upload ZIP</button>
  </div>
  <div id="uploadStatus" class="muted"></div>
  <div class="log" id="linkedinProgressLog" aria-live="polite"></div>
</div>
