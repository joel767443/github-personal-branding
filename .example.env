PORT=3000
SESSION_SECRET=change_me_in_production
GITHUB_TOKEN=github_token
GITHUB_USERNAME=github_handle
GITHUB_CLIENT_ID=github_client_id
GITHUB_CLIENT_SECRET=github_client_secret
DATABASE_URL="postgresql://{{db_user}}:{{db_password}}@{{db_host}}:{{db_port}}/{{db_name}}"

# Optional single-tenant deploy defaults (per-developer overrides in DB)
DEPLOY_REPO_URL=git@github.com:owner/repo.git
DEPLOY_README_REMOTE=readme
DEPLOY_BRANCH=main
DEPLOY_PORTFOLIO_AFTER_SYNC=1

# Redis + BullMQ (job queue). If unset, sync runs inline in the API process.
REDIS_URL=redis://127.0.0.1:6379

# 32-byte key, base64 (openssl rand -base64 32)
ENCRYPTION_MASTER_KEY=

# Stripe billing ($3 base + $1 per social price IDs from Dashboard)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASE=
STRIPE_PRICE_SOCIAL_FACEBOOK=
STRIPE_PRICE_SOCIAL_TWITTER=
STRIPE_PRICE_SOCIAL_LINKEDIN=
PUBLIC_APP_URL=http://localhost:3000

# Dev: allow sync without paid subscription
SUBSCRIPTION_BYPASS=1