# Copy to .env. Multi-tenant values live on `developers` (see prisma/schema.prisma model comments).
# Server-only: SESSION_SECRET, OAuth app defaults (GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET), DATABASE_URL, etc.

PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DB_NAME

REDIS_URL=
ENCRYPTION_MASTER_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASE=
STRIPE_PRICE_SOCIAL_FACEBOOK=
STRIPE_PRICE_SOCIAL_TWITTER=
STRIPE_PRICE_SOCIAL_LINKEDIN=
PUBLIC_APP_URL=http://localhost:3000
SUBSCRIPTION_BYPASS=1
